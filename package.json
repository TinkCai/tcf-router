{
  "name": "tcf-router",
  "version": "0.1.13-beta.3",
  "description": "provide a express-like tencent cloudbase function router and a local simulator",
  "main": "./dist/index.js",
  "types": "./types/index.d.ts",
  "bin": {
    "tcf": "./bin/index.js"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=text-lcov | coveralls",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:integration": "jest --testPathPattern=test/integration",
    "build": "tsc",
    "clean": "tsc --build --clean && rimraf dist types",
    "dev": "cd demo/ts-project && tcf dev",
    "format": "prettier --config .prettierrc.json --write \"{src,client,test}/**/*.{j,t}s\"",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "publish-beta": "npm publish --tag beta"
  },
  "repository": {
    "github": "https://github.com/TinkCai/tcf-router"
  },
  "keywords": [
    "cloudbase",
    "tencent",
    "lambda",
    "serverless",
    "wechat",
    "mini-program"
  ],
  "author": "Tink Cai",
  "license": "ISC",
  "devDependencies": {
    "@cloudbase/types": "^2.26.3",
    "@eslint/js": "^10.0.1",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "coveralls": "^3.1.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.5.0",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@cloudbase/manager-node": "5.3.1",
    "@types/cookie": "^1.0.0",
    "@types/cookie-signature": "^1.1.2",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "body-parser": "^2.2.2",
    "commander": "^14.0.3",
    "cookie": "^1.1.1",
    "cookie-signature": "^1.2.2",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "inquirer": "^13.3.2",
    "jsonwebtoken": "^9.0.3",
    "mime-types": "^3.0.2",
    "path-to-regexp": "^6.2.2",
    "prettier": "3.8.3",
    "tslib": "^2.8.1",
    "zip-local": "^0.3.5"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
